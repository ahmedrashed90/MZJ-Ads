rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function hasEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    function emailLower() {
      return request.auth.token.email.toLowerCase();
    }

    function myUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUidUserDoc() {
      return signedIn() && exists(myUserDocPath());
    }

    function myUserData() {
      return get(myUserDocPath()).data;
    }

    function hasUidRole(r) {
      return hasUidUserDoc() && myUserData().role == r;
    }

    function isAdminEmail() {
      return hasEmail() && emailLower() in [
        "hossamzayan10@gmail.com",
        "mr.ahmed_rashed@outlook.sa"
      ];
    }

    function isAdmin() {
      return isAdminEmail() || hasUidRole("admin");
    }

    function isMarketingManager() {
      return hasUidRole("marketing_manager") ||
             hasUidRole("marketing") ||
             hasUidRole("manager");
    }

    function isMember() {
      return hasUidRole("member") || hasUidRole("user");
    }

    function isFinisher() {
      return hasUidRole("finisher");
    }

    function isMemberOrFinisher() {
      return isMember() || isFinisher();
    }

    function isAdminOrMarketing() {
      return isAdmin() || isMarketingManager();
    }

    function canAccessPage(pageKey) {
      return isAdmin() || (
        hasUidUserDoc() &&
        myUserData().pages is list &&
        pageKey in myUserData().pages
      );
    }

    function fileLinkKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "files",
        "attachments",
        "links",
        "driveFiles",
        "driveLinks",
        "fileUrl",
        "fileUrls",
        "attachmentUrl",
        "attachmentUrls",
        "updatedAt",
        "updatedBy",
        "themeSettings"
      ]);
    }

    function userEditableKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "name",
        "displayName",
        "username",
        "phone",
        "photoURL",
        "updatedAt"
      ]);
    }

    function adminUserKeysValid() {
      return request.resource.data.keys().hasOnly([
        "uid",
        "id",
        "email",
        "emailLower",
        "name",
        "displayName",
        "username",
        "phone",
        "role",
        "department",
        "departmentId",
        "departmentIds",
        "pages",
        "pagesAccess",
        "themeSettings",
        "themeImageName",
        "themeImageData",
        "backgroundImageData",
        "backgroundImageUrl",
        "password",
        "status",
        "active",
        "createdAt",
        "createdBy",
        "updatedAt",
        "updatedBy"
      ]);
    }

    function departmentKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "name",
        "slug",
        "type",
        "description",
        "userIds",
        "users",
        "members",
        "memberUids",
        "memberEmails",
        "active",
        "isDefault",
        "createdAt",
        "createdBy",
        "updatedAt",
        "updatedBy"
      ]);
    }

    function templateKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "name",
        "type",
        "scope",
        "templateType",
        "fields",
        "headers",
        "rows",
        "data",
        "fileName",
        "fileUrl",
        "storagePath",
        "createdAt",
        "createdBy",
        "updatedAt",
        "updatedBy"
      ]);
    }

    function platformKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "name",
        "slug",
        "title",
        "label",
        "type",
        "platformType",
        "active",
        "isActive",
        "order",
        "sortOrder",
        "createdAt",
        "createdBy",
        "createdByName",
        "updatedAt",
        "updatedBy",
        "updatedByName"
      ]);
    }

    function budgetKeysValid() {
      return request.resource.data.keys().hasOnly([
        "workspaceTaskId",
        "campaignId",
        "campaignName",
        "campaignCode",
        "campaignType",

        "adType",
        "adName",
        "publishDate",
        "duration",
        "adsCount",
        "contentGoal",
        "expectedGoal",

        "budgetMode",
        "quantity",
        "platforms",
        "platformsTotal",
        "totalBudget",

        "createdAt",
        "createdBy",
        "updatedAt",
        "updatedBy"
      ]);
    }



    function marketingCreativeKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id", "name", "slug", "code", "description",
        "active", "isActive", "order", "sortOrder",
        "createdAt", "createdBy", "createdByName",
        "updatedAt", "updatedBy", "updatedByName"
      ]);
    }

    function marketingTaskTypeKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id", "name", "slug", "code", "description",
        "active", "isActive", "order", "sortOrder",
        "createdAt", "createdBy", "createdByName",
        "updatedAt", "updatedBy", "updatedByName"
      ]);
    }

    function marketingCampaignCodeKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id", "name", "slug", "code", "prefix", "sample", "description", "nextNumber",
        "active", "isActive", "order", "sortOrder",
        "createdAt", "createdBy", "createdByName",
        "updatedAt", "updatedBy", "updatedByName"
      ]);
    }

    function contentCategoryKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id", "name", "slug", "code", "description", "types", "contentTypes", "userIds", "users", "memberUids", "departmentId", "department", "contentDepartmentId",
        "active", "isActive", "order", "sortOrder",
        "createdAt", "createdBy", "createdByName",
        "updatedAt", "updatedBy", "updatedByName"
      ]);
    }

    function marketingCampaignKeysValid() {
      return request.resource.data.keys().hasOnly([
        "campaign_date", "campaign_code_key", "campaign_code", "campaign_name",
        "campaign_type", "campaign_type_id", "campaign_goal", "management_goal", "content_writer_brief",
        "structure_deadline", "request_status", "campaignCode", "campaignCodeId",
        "campaignCodePrefix", "campaignCodeShortCode", "campaignType", "campaignTypeId", "campaignSerial", "creatives",
        "publishSchedule", "budgetItems", "status", "source",
        "id", "name", "campaignName", "taskCount", "publishStages", "departmentTasks", "readiness", "stage",
        "resultsFile", "resultFile", "campaignLinks", "archivedAt", "archivedBy",
        "createdAt", "createdBy", "updatedAt", "updatedBy"
      ]);
    }


    function campaignTaskKeysValid() {
      return request.resource.data.keys().hasOnly([
        "id",
        "campaignId",
        "campaignName",
        "campaignCode",
        "creative",
        "product",
        "selectedCars",
        "selectedCar",
        "contentSectionId",
        "contentSectionName",
        "taskType",
        "assignedToUid",
        "assignedToId",
        "assignedToName",
        "assignedToEmail",
        "assignedToSearch",
        "displayName",
        "username",
        "userId",
        "userUid",
        "userName",
        "userEmail",
        "assigneeUid",
        "assigneeName",
        "assigneeEmail",
        "receivedConfirmed",
        "assignedDepartmentId",
        "assignedDepartmentName",
        "departmentRole",
        "received",
        "progress",
        "steps",
        "status",
        "attachments",
        "files",
        "fileUrl",
        "uploadedAt",
        "creativeIndex",
        "taskIndex",
        "source",
        "createdAt",
        "createdBy",
        "updatedAt",
        "updatedBy"
      ]);
    }


    function systemSettingsKeysValid() {
      return request.resource.data.keys().hasOnly([
        "systemName", "fontFamily", "direction", "colors", "themeImageName", "themeImageData", "backgroundImageData", "backgroundImageUrl", "stockCarStatusMap", "stockCarMeta", "createdAt", "createdBy", "updatedAt", "updatedBy"
      ]);
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if adminUserKeysValid();
      allow update: if adminUserKeysValid() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(["themeSettings", "updatedAt"]);
      allow delete: if true;
    }

    match /departments/{docId} {
      allow read: if true;
      allow create, update: if departmentKeysValid();
      allow delete: if true;
    }

    match /campaign_templates/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /templates/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /marketing_campaign_types/{docId} {
      allow read, create, update, delete: if true;
    }

    match /marketing_platforms/{docId} {
      allow read, create, update, delete: if true;
    }

    match /marketing_funnels/{docId} {
      allow read, create, update, delete: if true;
    }

    match /required_content_types/{docId} {
      allow read, create, update, delete: if true;
    }

    match /campaign_budgets/{docId} {
      allow read: if true;
      allow create, update: if budgetKeysValid();
      allow delete: if true;
    }

    match /marketing_budgets/{docId} {
      allow read: if true;
      allow create, update: if budgetKeysValid();
      allow delete: if true;
    }

    match /campaign_reviews/{docId} {
      allow read, create, update, delete: if true;
    }

    match /media_specs/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /workspaces/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /workspace_tasks/{taskId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /stock_tasks/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      function stockAllowedKeys() {
        return [
          "specKey",
          "specId",
          "montage",
          "montageDetails",
          "montageMonths",
          "usedColors",
          "inAgenda",
          "agendaMonth",
          "agendaYear",
          "specReel",
          "photo",
          "updatedAt"
        ];
      }

      function validStockFinishData() {
        return request.resource.data.montage == "نعم" &&
          (
            !request.resource.data.keys().hasAny(["montageDetails"]) ||
            request.resource.data.montageDetails == "" ||
            request.resource.data.montageDetails == "نعم" ||
            request.resource.data.montageDetails == "لا" ||
            request.resource.data.montageDetails == "صور + ريل مواصفات" ||
            request.resource.data.montageDetails == "صور فقط" ||
            request.resource.data.montageDetails == "ريل مواصفات فقط"
          );
      }

      allow create: if isMemberOrFinisher() &&
        request.resource.data.keys().hasOnly(stockAllowedKeys()) &&
        validStockFinishData();

      allow update: if isMemberOrFinisher() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(stockAllowedKeys()) &&
        validStockFinishData();
    }

    match /stock_tasks_backup/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      allow create, update: if isMemberOrFinisher() &&
        request.resource.data.montage == "نعم" &&
        (
          !request.resource.data.keys().hasAny(["montageDetails"]) ||
          request.resource.data.montageDetails == "نعم" ||
          request.resource.data.montageDetails == "لا"
        );
    }

    match /daily_tasks/{docId} {
      allow read: if isAdmin() || canAccessPage("daily-tasks");
      allow create, update, delete: if isAdmin();
      allow update: if signedIn() && fileLinkKeysOnly();
    }

    match /daily_docs/{docId} {
      allow read: if isAdmin() || canAccessPage("daily-tasks");
      allow create, update, delete: if isAdmin();
      allow update: if signedIn() && fileLinkKeysOnly();
    }

    match /departments_tasks/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /content_tasks/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }



    match /marketing_creatives/{docId} {
      allow read: if true;
      allow create, update: if marketingCreativeKeysValid();
      allow delete: if true;
    }

    match /marketing_task_types/{docId} {
      allow read: if true;
      allow create, update: if marketingTaskTypeKeysValid();
      allow delete: if true;
    }

    match /marketing_campaign_codes/{docId} {
      allow read: if true;
      allow create, update: if marketingCampaignCodeKeysValid();
      allow delete: if true;
    }

    match /content_categories/{docId} {
      allow read: if true;
      allow create, update: if contentCategoryKeysValid();
      allow delete: if true;
    }

    match /marketing_campaigns/{docId} {
      allow read: if true;
      allow create, update: if marketingCampaignKeysValid();
      allow delete: if true;
    }

    match /marketing_stock_cars/{docId} {
      allow read: if true;
      allow create, update, delete: if true;
    }


    match /campaign_tasks/{docId} {
      allow read: if true;
      allow create, update: if campaignTaskKeysValid();
      allow delete: if true;
    }



    match /system_settings/{docId} {
      allow read: if true;
      allow create, update: if systemSettingsKeysValid();
      allow delete: if true;
    }

    match /{document=**} {
      allow read, create, update, delete: if false;
    }
  }
}